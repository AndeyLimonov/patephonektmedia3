<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="match_parent"-->
<!--        android:layout_gravity="start"-->
<!--        app:menu="@menu/drawer_menu"-->
<!--        app:theme="@style/Theme.Patephone"/>-->

</androidx.drawerlayout.widget.DrawerLayout>
