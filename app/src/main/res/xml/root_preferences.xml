<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:title="@string/player_header">
        <SwitchPreference
            android:defaultValue="false"
            android:key="preference_shuffle"
            android:title="@string/shuffle_title" />

    </PreferenceCategory>
    <ListPreference
        android:defaultValue="0"
        android:entries="@array/repeat_titles"
        android:entryValues="@array/repeat_values"
        android:key="list_preference_repeat"
        android:title="@string/repeat_title"
        app:useSimpleSummaryProvider="true"/>
</PreferenceScreen>